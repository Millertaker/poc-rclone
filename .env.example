# Local credentials for running scripts/*.sh against dotCMS Dev.
#
# This file is gitignored (see .gitignore) and must NEVER be committed.
# In CI these same variable names are populated from GitHub Actions
# repository secrets instead (see .github/workflows/deploy-to-dev.yml).
#
# Usage:
#   set -a; source .env; set +a
#   ./scripts/configure-rclone.sh
#   ./scripts/deploy-dev.sh      # or ./scripts/pull-dev.sh

# WebDAV endpoint for the Dev dotCMS instance
DOTCMS_DEV_WEBDAV_URL=

# WebDAV/dotCMS credentials
DOTCMS_USER=
DOTCMS_PASS=

# Public URL of the Dev environment, used by the smoke check
DOTCMS_DEV_URL=

# Optional: numeric dotCMS language id (defaults to 1 / en-us if left blank)
DOTCMS_LANGUAGE_ID=
